{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "FastAPI (uvicorn)",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "app.main:app",
                "--reload",
                "--host", "0.0.0.0",
                "--port", "8000"
            ],
            "jinja": true,
            "justMyCode": true,
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "Uvicorn running on http://.*:(\\d+)",
                "uriFormat": "http://localhost:%s/docs"
            }
        }
    ]
}
